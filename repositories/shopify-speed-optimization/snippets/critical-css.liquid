{% comment %}
  Snippet: Above-The-Fold Critical CSS Rendering
  Author: Sayanthan S.
{% endcomment %}

<style id="CriticalCSS">
  /* Font Display Swap Rule */
  @font-face {
    font-family: 'ShopifySans';
    font-display: swap;
  }
  
  /* Reset & Baseline Layout Protection */
  *, *::before, *::after { box-sizing: border-box; }
  body { margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }

  /* Hero & Header Container Aspect Ratio Protection (Prevents CLS) */
  .header-wrapper, .hero-section {
    contain-intrinsic-size: 1000px 400px;
    content-visibility: auto;
  }
  img { max-width: 100%; height: auto; display: block; }
</style>
